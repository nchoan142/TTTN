<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Row 1: Name + Category chip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_venue_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Sân Pickleball ABC"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pickleball"
                android:textColor="@color/green_dark"
                android:textSize="11sp"
                android:background="@drawable/bg_chip_green"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- Row 2: Address -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_location"
                android:contentDescription="Địa chỉ" />

            <TextView
                android:id="@+id/tv_address"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="123 Đường ABC, Quận 1, TP.HCM"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:paddingStart="6dp" />

        </LinearLayout>

        <!-- Row 3: Distance placeholder -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_map"
                android:contentDescription="Khoảng cách" />

            <TextView
                android:id="@+id/tv_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đang tính khoảng cách..."
                android:textColor="@color/text_hint"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="6dp" />

        </LinearLayout>

        <!-- Row 4: Rating + Hours -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_star"
                android:contentDescription="Đánh giá" />

            <TextView
                android:id="@+id/tv_rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4.8"
                android:textColor="#FF8F00"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingStart="4dp" />

            <View
                android:layout_width="1dp"
                android:layout_height="14dp"
                android:background="@color/divider"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp" />

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_time"
                android:contentDescription="Giờ" />

            <TextView
                android:id="@+id/tv_hours"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="06:00 - 22:00"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:paddingStart="4dp" />

        </LinearLayout>

        <!-- Row 5: Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_direction"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Chỉ đường"
                android:textColor="@color/green_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:backgroundTint="@color/bg_card"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginEnd="8dp"
                app:cornerRadius="8dp"
                app:strokeColor="@color/green_primary"
                app:strokeWidth="1dp"
                app:rippleColor="#332E7D32" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_detail"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Xem chi tiết"
                android:textColor="@color/text_white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_green"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="8dp"
                app:rippleColor="#33FFFFFF" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
