<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2E7D32">

    <!-- Vòng tròn trang trí góc trên bên phải -->
    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-60dp"
        android:layout_marginEnd="-60dp"
        android:background="@drawable/bg_circle_white_15"
        android:elevation="0dp" />

    <!-- Vòng tròn trang trí góc trên bên phải nhỏ hơn -->
    <View
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="80dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_circle_white_15"
        android:elevation="0dp" />

    <!-- Vòng tròn trang trí góc dưới bên trái -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="-50dp"
        android:layout_marginStart="-50dp"
        android:background="@drawable/bg_circle_white_15"
        android:elevation="0dp" />

    <!-- Vòng tròn trang trí góc dưới bên trái nhỏ hơn -->
    <View
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="80dp"
        android:layout_marginStart="20dp"
        android:background="@drawable/bg_circle_white_15"
        android:elevation="0dp" />

    <!-- Nội dung chính giữa -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Icon ứng dụng -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_sport_pickleball"
            android:contentDescription="SportBooking Logo" />

        <!-- Tên ứng dụng -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="SportBooking"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:fontFamily="sans-serif-medium" />

        <!-- Slogan -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Đặt sân thể thao dễ dàng"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            android:letterSpacing="0.01" />

    </LinearLayout>

    <!-- ProgressBar ở cuối màn hình -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="40dp"
        android:paddingBottom="60dp">

        <ProgressBar
            android:id="@+id/progress_bar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:indeterminate="true"
            android:progressTint="@color/green_accent"
            android:progressBackgroundTint="#4DFFFFFF"
            android:indeterminateTint="@color/green_accent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"
            android:text="Đang tải..."
            android:textColor="#99FFFFFF"
            android:textSize="12sp" />

    </LinearLayout>

</FrameLayout>
