<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <!-- Header xanh lá -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_header_green">

        <!-- Row chính của header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                android:padding="12dp"
                android:contentDescription="Quay lại" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Lịch sử đặt sân"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Tab lọc nhanh -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tab_all"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Tất cả"
                    android:textColor="#2E7D32"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_tab_active"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tab_pending"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Chờ duyệt"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:background="@drawable/bg_tab_inactive"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tab_confirmed"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Đã xác nhận"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:background="@drawable/bg_tab_inactive"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tab_completed"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Hoàn thành"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:background="@drawable/bg_tab_inactive"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tab_cancelled"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Đã huỷ"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:background="@drawable/bg_tab_inactive"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

            </LinearLayout>

        </HorizontalScrollView>

    </LinearLayout>

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="@color/green_primary" />

    <!-- SwipeRefreshLayout bọc RecyclerView -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_bookings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:overScrollMode="never"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Empty state khi không có lịch -->
    <LinearLayout
        android:id="@+id/ll_empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_booking"
            android:alpha="0.3"
            android:contentDescription="Không có lịch" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Bạn chưa có lịch đặt nào"
            android:textColor="#9E9E9E"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Hãy đặt sân yêu thích của bạn ngay!"
            android:textColor="#BDBDBD"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_explore"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_button_green"
            android:text="Tìm sân ngay"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            app:cornerRadius="22dp"
            app:rippleColor="#33FFFFFF" />

    </LinearLayout>

</LinearLayout>
