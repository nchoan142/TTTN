<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="72dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="4dp"
    android:background="?attr/selectableItemBackgroundBorderless">

    <!-- Vòng tròn chứa icon danh mục -->
    <FrameLayout
        android:id="@+id/fl_category_icon"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:background="@drawable/bg_category_circle">

        <ImageView
            android:id="@+id/iv_category_icon"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_sport_pickleball"
            android:contentDescription="Danh mục" />

    </FrameLayout>

    <!-- Tên danh mục -->
    <TextView
        android:id="@+id/tv_category_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Pickleball"
        android:textColor="#424242"
        android:textSize="11sp"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end" />

</LinearLayout>
