<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_green"
        android:paddingTop="36dp"
        android:paddingBottom="20dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_centerVertical="true"
            android:padding="6dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Quay lại" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Khám phá"
            android:textColor="@color/text_white"
            android:textSize="20sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <!-- Filter chips - Category -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingTop="12dp"
        android:paddingBottom="4dp"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/ll_category_chips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/chip_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tất cả"
                android:textColor="@color/text_white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/bg_chip_active"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_pickleball"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pickleball"
                android:textColor="@color/green_primary"
                android:textSize="13sp"
                android:background="@drawable/bg_chip"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_badminton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cầu lông"
                android:textColor="@color/green_primary"
                android:textSize="13sp"
                android:background="@drawable/bg_chip"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_football"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bóng đá"
                android:textColor="@color/green_primary"
                android:textSize="13sp"
                android:background="@drawable/bg_chip"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_tennis"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tennis"
                android:textColor="@color/green_primary"
                android:textSize="13sp"
                android:background="@drawable/bg_chip"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_volleyball"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bóng chuyền"
                android:textColor="@color/green_primary"
                android:textSize="13sp"
                android:background="@drawable/bg_chip"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chip_basketball"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bóng rổ"
                android:textColor="@color/green_primary"
                android:textSize="13sp"
                android:background="@drawable/bg_chip"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- Sort options -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingTop="4dp"
        android:paddingBottom="12dp"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/ll_sort_chips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/sort_rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đánh giá cao nhất"
                android:textColor="@color/text_white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_chip_active"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/sort_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giá thấp nhất"
                android:textColor="@color/green_primary"
                android:textSize="12sp"
                android:background="@drawable/bg_chip"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/sort_nearest"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gần nhất"
                android:textColor="@color/green_primary"
                android:textSize="12sp"
                android:background="@drawable/bg_chip"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- Content area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_venues"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="4dp"
            android:clipToPadding="false" />

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/ll_empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_search"
                android:alpha="0.3"
                android:contentDescription="Không có kết quả" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Không tìm thấy sân nào"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminateTint="@color/green_primary" />

    </FrameLayout>

</LinearLayout>
