<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <!-- Anh san lon -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content" >

        <ImageView
            android:id="@+id/iv_venue_image"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:contentDescription="Anh san" />

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="top|start"
            android:layout_margin="16dp"
            android:elevation="10dp"
            android:translationZ="10dp"
            android:background="@drawable/bg_icon_button_white"
            android:src="@drawable/ic_arrow_back"
            android:padding="10dp" />
    </FrameLayout>

    <!-- Header xanh la 160dp -->
    <FrameLayout
        android:id="@+id/fl_header_green"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="@drawable/bg_header_green">

        <!-- Vong tron trang tri -->
        <View
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="-30dp"
            android:layout_marginEnd="-30dp"
            android:background="@drawable/bg_circle_white_15" />

        <!-- Nut Back -->
<!--        <ImageButton-->
<!--            android:id="@+id/btn_back"-->
<!--            android:layout_width="44dp"-->
<!--            android:layout_height="44dp"-->
<!--            android:layout_gravity="top|start"-->
<!--            android:layout_margin="12dp"-->
<!--            android:background="@drawable/bg_icon_button_white"-->
<!--            android:src="@drawable/ic_arrow_back"-->
<!--            android:contentDescription="Quay l\u1EA1i"-->
<!--            android:padding="10dp" />-->

        <!-- Thong tin san trong header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="60dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <!-- Ten san -->
            <TextView
                android:id="@+id/tv_venue_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="S\u00E2n Pickleball Trung T\u00E2m"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Dia chi -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:contentDescription="Địa chỉ"
                    android:src="@drawable/ic_map" />

                <TextView
                    android:id="@+id/tv_venue_address"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:paddingStart="6dp"
                    android:text="123 Đường ABC, Quận 1, TP.HCM"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- Row danh gia sao -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="Sao 1"
                    android:src="@drawable/ic_star" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="Sao 2"
                    android:src="@drawable/ic_star" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="Sao 3"
                    android:src="@drawable/ic_star" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="Sao 4"
                    android:src="@drawable/ic_star" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="Sao 5"
                    android:src="@drawable/ic_star" />

                <TextView
                    android:id="@+id/tv_rating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="6dp"
                    android:text="5.0 (128 đánh giá)"
                    android:textColor="#FFECB3"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>



    </FrameLayout>

    <!-- Noi dung cuon ben duoi header -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- Card thong tin lien he -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Th\u00F4ng tin li\u00EAn h\u1EC7"
                        android:textColor="@color/green_dark"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <!-- Dien thoai -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_info_icon_circle">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_phone"
                                android:contentDescription="Điện thoại" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="\u0110i\u1EC7n tho\u1EA1i"
                                android:textColor="#9E9E9E"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tv_phone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0901 234 567"
                                android:textColor="#212121"
                                android:textSize="14sp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Dia chi day du -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_info_icon_circle">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_map"
                                android:contentDescription="Địa chỉ" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="\u0110\u1ECBa ch\u1EC9"
                                android:textColor="#9E9E9E"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tv_full_address"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="123 Đường ABC, Phường XYZ, Quận 1, TP.HCM"
                                android:textColor="#212121"
                                android:textSize="14sp"
                                android:maxLines="2" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Gio mo cua -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_info_icon_circle">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_time"
                                android:contentDescription="Giờ mở cửa" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Gi\u1EDD m\u1EDF c\u1EEDa"
                                android:textColor="#9E9E9E"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tv_open_hours"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="05:00 - 23:00 (Tất cả các ngày)"
                                android:textColor="#212121"
                                android:textSize="14sp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Card gia san -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_info_icon_circle">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="$"
                            android:textColor="@color/green_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gi\u00E1 thu\u00EA s\u00E2n"
                            android:textColor="#9E9E9E"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="150,000\u0111 / slot"
                            android:textColor="@color/green_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Section "San" - danh sach san -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="S\u00E2n thi \u0111\u1EA5u"
                            android:textColor="@color/green_dark"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_court_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 s\u00E2n"
                            android:textColor="@color/green_primary"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <!-- Container de them court chips dong -->
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_courts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleLine="false"
                        app:chipSpacingHorizontal="8dp"
                        app:chipSpacingVertical="8dp" />

                    <!-- Placeholder khi khong co san -->
                    <TextView
                        android:id="@+id/tv_courts_empty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="\u0110ang t\u1EA3i danh s\u00E1ch s\u00E2n..."
                        android:textColor="#9E9E9E"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:visibility="visible" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Section "Danh gia" -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header danh gia -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="\u0110\u00E1nh gi\u00E1"
                            android:textColor="@color/green_dark"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <!-- Rating summary -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_star"
                                android:contentDescription="Sao" />

                            <TextView
                                android:id="@+id/tv_review_rating"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.0"
                                android:textColor="@color/accent"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:paddingStart="4dp" />

                            <TextView
                                android:id="@+id/tv_review_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="(0)"
                                android:textColor="#9E9E9E"
                                android:textSize="12sp"
                                android:paddingStart="4dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginBottom="12dp" />

                    <!-- Placeholder khi chua co danh gia -->
                    <TextView
                        android:id="@+id/tv_reviews_empty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ch\u01B0a c\u00F3 \u0111\u00E1nh gi\u00E1 n\u00E0o"
                        android:textColor="#9E9E9E"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:visibility="visible" />

                    <!-- Danh sach review -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_reviews"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:visibility="gone" />

                    <!-- Nut viet danh gia -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_write_review"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="12dp"
                        android:text="Vi\u1EBFt \u0111\u00E1nh gi\u00E1"
                        android:textColor="@color/green_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:backgroundTint="#FFFFFF"
                        app:cornerRadius="10dp"
                        app:strokeColor="@color/green_primary"
                        app:strokeWidth="1dp"
                        app:icon="@drawable/ic_star"
                        app:iconGravity="textStart"
                        app:iconSize="16dp"
                        app:iconTint="@color/accent"
                        app:rippleColor="#1A2E7D32" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

    <!-- Nut Dat lich full width o duoi -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        android:elevation="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_book_now"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_button_gold"
            android:text="\u0110\u1EB6T L\u1ECACH NGAY"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:letterSpacing="0.05"
            app:cornerRadius="12dp"
            app:rippleColor="#33FFFFFF" />

    </LinearLayout>

</LinearLayout>
