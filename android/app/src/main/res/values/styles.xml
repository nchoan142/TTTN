<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ================================================================
         BASE APP THEME
    ================================================================ -->
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>

        <!-- Status & Navigation bar -->
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/primary_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Window background -->
        <item name="android:windowBackground">@color/bg_main</item>
        <item name="android:colorBackground">@color/bg_main</item>

        <!-- Text appearance -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>

        <!-- Material component overrides -->
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnPrimary">@color/text_white</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="colorError">#B00020</item>

        <!-- Ripple -->
        <item name="colorControlHighlight">#1A2E7D32</item>

        <!-- Action bar -->
        <item name="actionBarStyle">@style/AppTheme.ActionBar</item>
        <item name="toolbarStyle">@style/AppTheme.Toolbar</item>
    </style>

    <!-- ================================================================
         ACTION BAR
    ================================================================ -->
    <style name="AppTheme.ActionBar" parent="Widget.AppCompat.ActionBar.Solid">
        <item name="background">@color/primary</item>
        <item name="titleTextStyle">@style/AppTheme.ActionBar.Title</item>
    </style>

    <style name="AppTheme.ActionBar.Title" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/text_white</item>
        <item name="android:textSize">18sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="AppTheme.Toolbar" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@color/primary</item>
        <item name="titleTextColor">@color/text_white</item>
        <item name="subtitleTextColor">@color/primary_light</item>
    </style>

    <!-- ================================================================
         NO ACTION BAR (for custom toolbar / fullscreen layouts)
    ================================================================ -->
    <style name="AppTheme.NoActionBar" parent="AppTheme">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <!-- ================================================================
         SPLASH THEME
    ================================================================ -->
    <style name="SplashTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowBackground">@color/primary</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
    </style>

    <!-- ================================================================
         FULLSCREEN (Video / Immersive)
    ================================================================ -->
    <style name="AppTheme.Fullscreen" parent="AppTheme.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">@color/transparent</item>
    </style>

    <!-- ================================================================
         BUTTONS
    ================================================================ -->

    <!-- Primary Green Button -->
    <style name="ButtonPrimary" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/bg_button_green</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="backgroundTint">@null</item>
        <item name="rippleColor">@color/primary_dark</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="elevation">4dp</item>
    </style>

    <!-- Accent Gold / Amber Button (CTA) -->
    <style name="ButtonAccent" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/bg_button_gold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="backgroundTint">@null</item>
        <item name="rippleColor">@color/accent_dark</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="elevation">4dp</item>
    </style>

    <!-- Outlined / Secondary Button -->
    <style name="ButtonOutlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:paddingTop">11dp</item>
        <item name="android:paddingBottom">11dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="strokeColor">@color/primary</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="rippleColor">#1A2E7D32</item>
    </style>

    <!-- Text Button -->
    <style name="ButtonText" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="rippleColor">#1A2E7D32</item>
    </style>

    <!-- ================================================================
         INPUT FIELDS
    ================================================================ -->
    <style name="InputField" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/bg_input</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/divider</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="startIconTint">@color/text_secondary</item>
        <item name="endIconTint">@color/text_secondary</item>
        <item name="errorTextColor">@color/slot_booked</item>
        <item name="errorIconDrawable">@null</item>
        <item name="placeholderTextColor">@color/text_hint</item>
    </style>

    <style name="InputField.EditText" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <!-- ================================================================
         CARDS
    ================================================================ -->
    <style name="CardVenue" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardMaxElevation">8dp</item>
        <item name="contentPadding">0dp</item>
        <item name="rippleColor">#1A2E7D32</item>
    </style>

    <style name="CardBooking" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- ================================================================
         TEXT APPEARANCES
    ================================================================ -->
    <style name="TextTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="TextSubtitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextBody" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextCaption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="TextPrice">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextPriceLarge">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">24sp</item>
        <item name="android:fontFamily">sans-serif-bold</item>
    </style>

    <style name="TextSectionHeader">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <!-- ================================================================
         BOTTOM NAVIGATION
    ================================================================ -->
    <style name="BottomNavTheme" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemIconTint">@color/selector_bottom_nav</item>
        <item name="itemTextColor">@color/selector_bottom_nav</item>
        <item name="itemBackground">@null</item>
        <item name="elevation">8dp</item>
    </style>

    <!-- ================================================================
         CHIPS
    ================================================================ -->
    <style name="ChipSport" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="chipBackgroundColor">@color/chip_bg</item>
        <item name="chipStrokeColor">@color/divider</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
        <item name="chipCornerRadius">20dp</item>
        <item name="chipMinHeight">36dp</item>
        <item name="chipBackgroundColor">@color/chip_bg_selector</item>
    </style>

    <!-- ================================================================
         DIALOGS
    ================================================================ -->
    <style name="AppDialog" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="buttonBarPositiveButtonStyle">@style/ButtonText</item>
        <item name="buttonBarNegativeButtonStyle">@style/ButtonText</item>
    </style>

    <!-- ================================================================
         TOOLBAR (used in activity/fragment directly)
    ================================================================ -->
    <style name="ToolbarGreen" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@color/primary</item>
        <item name="titleTextColor">@color/text_white</item>
        <item name="subtitleTextColor">#B2FFFFFF</item>
        <item name="navigationIconTint">@color/text_white</item>
    </style>

</resources>
