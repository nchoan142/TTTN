<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/badminton_icon"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/AppTheme">

        <activity
            android:name=".activity.SplashActivity"
            android:theme="@style/AppTheme.NoActionBar"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activity.LoginActivity"
            android:theme="@style/AppTheme.NoActionBar"
            android:exported="false" />

        <activity
            android:name=".activity.RegisterActivity"
            android:theme="@style/AppTheme.NoActionBar"
            android:exported="false" />

        <activity
            android:name=".activity.MainActivity"
            android:theme="@style/AppTheme.NoActionBar"
            android:exported="false" />

        <activity
            android:name=".activity.VenueDetailActivity"
            android:theme="@style/AppTheme.NoActionBar"
            android:exported="false" />

        <activity
            android:name=".activity.BookingActivity"
            android:theme="@style/AppTheme.NoActionBar"
            android:exported="false" />

        <activity
            android:name=".activity.MyBookingsActivity"
            android:theme="@style/AppTheme.NoActionBar"
            android:exported="false" />

        <activity
            android:name=".activity.ExploreActivity"
            android:theme="@style/AppTheme.NoActionBar"
            android:exported="false" />

        <activity
            android:name=".activity.MapActivity"
            android:theme="@style/AppTheme.NoActionBar"
            android:exported="false" />

        <activity
            android:name=".activity.BookingDetailActivity"
            android:theme="@style/AppTheme.NoActionBar"
            android:exported="false" />

        <activity
            android:name=".activity.AccountActivity"
            android:theme="@style/AppTheme.NoActionBar"
            android:exported="false" />

        <activity
            android:name=".activity.AdminActivity"
            android:theme="@style/AppTheme.NoActionBar"
            android:exported="false" />

    </application>

</manifest>
